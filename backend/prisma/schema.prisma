generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  email        String
  comment      String?
  ordersCount  Int      @default(0)
  measurements Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders    Order[]
  fittings  Fitting[]
}

model Order {
  id            Int      @id @default(autoincrement())
  orderNumber   String   @unique
  clientId      Int
  product       String
  price         Int
  paidAmount    Int      @default(0)
  paymentStatus String   @default("Не оплачено")
  status        String   @default("В работе")
  deadline      DateTime
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id])
  fittings Fitting[]
}

model Fitting {
  id        Int      @id @default(autoincrement())
  clientId  Int
  orderId   Int
  date      DateTime
  time      String
  status    String   @default("Запланирована")
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
}